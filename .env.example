# ============================================
# OPENCLAW PLATFORM — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values.
# See SETUP_GUIDE.md for where to get each one.
# ============================================

# ── Database (PostgreSQL) ──
# The connection string to your PostgreSQL database.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://openclaw:your-strong-password@localhost:5432/openclaw

# ── Redis ──
# Redis connection string for caching and rate limiting.
REDIS_URL=redis://localhost:6379

# ── Stripe (Payments) ──
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Subscription Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_1T2f738gBaiDIsrpdUHCp6Lu
STRIPE_PRICE_PRO=price_1T2f808gBaiDIsrpOe1jXIog
STRIPE_PRICE_BUSINESS=price_1T2f8c8gBaiDIsrpXawmyKyc

# Token Package Price IDs (one-time products in Stripe)
STRIPE_PRICE_TOKENS_500K=price_1T2f9D8gBaiDIsrpH5FpBGA9
STRIPE_PRICE_TOKENS_1200K=price_1T2f9o8gBaiDIsrplp9FmQVc
STRIPE_PRICE_TOKENS_3500K=price_1T2fAK8gBaiDIsrpFmCGcZd8
STRIPE_PRICE_TOKENS_8M=price_1T2fAi8gBaiDIsrpPvasZ3hd

# ── AI Providers ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── AWS S3 (User Data Storage) ──
# Get from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=AKIA_xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET_PREFIX=openclaw-users

# ── Email (Resend) ──
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ── Platform URLs ──
# Replace "yourdomain.com" with your actual domain.
PLATFORM_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
DOMAIN=yourdomain.com

# ── Google Sign-In ──
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application"
GOOGLE_CLIENT_ID=123456789-abcdef.apps.googleusercontent.com

# This goes in the dashboard .env.local too (with NEXT_PUBLIC_ prefix)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-abcdef.apps.googleusercontent.com

# ── Security Secrets ──
# Generate each with: openssl rand -hex 32
JWT_SECRET=6a51c8246319a854a6cd54f147b10be8a1042f13f696240d9a21a9396b806658
ENCRYPTION_KEY=38e4267d3bbe6cc0ddbb6b201cecf5898245f4a51fcfdebc1df33908fe8a2431
INTERNAL_SECRET=7faf0b35d03e1faf26c9f8ebacf72bdd30a1f5cd19b40a334c98a2c9de834b8b

# ── Server Hosting (Optional — for auto-scaling) ──
# Only needed if you want automatic worker provisioning. See WORKER_SETUP.md.
# Hostinger: https://hostinger.com → API / API Access → Generate token
HOSTINGER_API_KEY=

# Optional — auto-discovered from Hostinger API if missing. Set to override.
# HOSTINGER_ITEM_ID=    # Catalog price ID (e.g. hostinger_vps_kvm1_1m_1)
# HOSTINGER_TEMPLATE_ID=   # OS template ID (e.g. 4 for Ubuntu 22.04)
# HOSTINGER_DATA_CENTER_ID=  # Data center ID (e.g. 1)

# Post-install script ID (integer). Create via API or dashboard, use returned ID.
HOSTINGER_SCRIPT_ID=

# (Optional) SSH public key to inject into new workers so the API can SSH in.
# This is the contents of ~/.ssh/openclaw_worker.pub (one line, starts with "ssh-ed25519 ...")
# WORKER_SSH_PUBLIC_KEY=

# SSH from API server to workers (base64-encoded private key)
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/openclaw_worker -N ""
# Encode:   base64 -w0 ~/.ssh/openclaw_worker  (or base64 -i ~/.ssh/openclaw_worker | tr -d '\n' on macOS)
# SSH_PRIVATE_KEY=

# ── Browserless (Optional — for web browsing feature) ──
# Get from: https://www.browserless.io
# Only needed for Pro/Business plans with browser access.
# BROWSERLESS_TOKEN=xxxxxxxxxxxx
